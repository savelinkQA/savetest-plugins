{
  "name": "readyapi-composite-parser",
  "version": "1.1.0",
  "display_name": "ReadyAPI Composite Parser",
  "description": "Parser for ReadyAPI/SoapUI composite project test cases (XML)",
  "language": "readyapi",
  "supported_extensions": [".xml"],
  "file_patterns": ["**/*.xml"],
  "api_version": "1.1",
  "endpoints": {
    "parse": "/parse",
    "parse_repo": "/parse_repo",
    "can_parse": "/can_parse",
    "health": "/health",
    "config": "/config"
  },
  "config": {
    "port": 8000,
    "timeout": 30,
    "repo_timeout": 600
  }
}
